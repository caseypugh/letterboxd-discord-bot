DISCORD_CLIENT_ID=
DISCORD_TOKEN=

# Local development uses a SQLite file (created automatically on first
# `pnpm db:migrate`). The path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# Production: point at a Turso database (https://turso.tech). When
# TURSO_DATABASE_URL is set it takes precedence over DATABASE_URL.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=

# Optional: set to enable Sentry error reporting. Leave blank to disable.
SENTRY_DSN=
