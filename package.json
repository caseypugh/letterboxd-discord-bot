{
	"name": "letterboxd-discord-bot",
	"version": "0.1.0",
	"description": "Letterbox Discord Bot",
	"main": "bot.js",
	"repository": "https://github.com/caseypugh/letterboxd-discord-bot",
	"author": "Casey Pugh",
	"license": "MIT",
	"engines": {
		"node": "24"
	},
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"start": "pnpm db:deploy && pnpm db:generate && NODE_PATH=./ ts-node src/app.ts",
		"up": "pnpm db:migrate && pnpm dev",
		"dev": "NODE_PATH=./ nodemon --watch \"src/**/*\" --ext ts --exec \"ts-node src/app.ts\"",
		"test-feed": "NODE_PATH=./ ts-node src/tools/test-feed.ts",
		"test": "ts-node test.ts",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "NODE_PATH=./ ts-node src/tools/migrate.ts",
		"db:generate": "prisma generate"
	},
	"dependencies": {
		"@discordjs/builders": "^0.13.0",
		"@discordjs/rest": "^0.4.1",
		"@libsql/client": "^0.17.4",
		"@prisma/adapter-libsql": "^6.19.3",
		"@prisma/client": "^6.19.3",
		"@sentry/node": "^10.53.1",
		"cron": "^4.4.0",
		"discord-api-types": "^0.32.1",
		"discord.js": "^13.17.1",
		"dotenv": "^17.4.2",
		"node-fetch": "^2.7.0",
		"promise-delay-ts": "^1.0.1",
		"rss-parser": "^3.13.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@types/node": "^24.12.4",
		"@types/node-fetch": "^2.6.13",
		"@types/pg": "^8.20.0",
		"nodemon": "^3.1.14",
		"pg": "^8.22.0",
		"prisma": "^6.19.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"prisma"
		]
	}
}
